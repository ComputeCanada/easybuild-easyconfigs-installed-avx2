# Built with EasyBuild version 5.3.0 on 2026-06-25_15-37-08
easyblock = 'Tarball'

name = 'BEAST-X'
version = '10.5.0'

homepage = 'https://beast.community'
description = """
BEAST is a cross-platform program for Bayesian analysis of molecular sequences
using MCMC. It is entirely orientated towards rooted, time-measured phylogenies inferred using
strict or relaxed molecular clock models. It can be used as a method of reconstructing phylogenies
but is also a framework for testing evolutionary hypotheses without conditioning on a single
tree topology. BEAST uses MCMC to average over tree space, so that each tree is weighted
proportional to its posterior probability.
"""

toolchain = {'name': 'GCCcore', 'version': '12.3.0'}

github_account = 'beast-dev'

source_urls = ['https://github.com/%(github_account)s/beast-mcmc/releases/download/v%(version)s']
sources = ['BEAST_X_v%(version)s.tgz']
checksums = ['b4726b4f3b8b7e627df334a7eb52be1a95dca936e73030beba2b9929f9918f8c']

dependencies = [
    ('beagle-lib', '4.0.1'),
    ('Java', '17', '', SYSTEM),
]

sanity_check_paths = {
    'files': ['bin/beast', 'bin/beauti'],
    'dirs': []
}

sanity_check_commands = ["beast -help"]

moduleclass = 'bio'

