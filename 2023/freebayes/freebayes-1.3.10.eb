# Built with EasyBuild version 5.3.0 on 2026-07-20_07-59-06
easyblock = 'MesonNinja'

name = 'freebayes'
version = '1.3.10'

homepage = 'https://github.com/freebayes/freebayes'
description = """FreeBayes is a Bayesian genetic variant detector designed to find small
 polymorphisms, specifically SNPs (single-nucleotide polymorphisms), indels (insertions and
 deletions), MNPs (multi-nucleotide polymorphisms), and complex events (composite insertion and
 substitution events) smaller than the length of a short-read sequencing alignment.
"""

toolchain = {'name': 'GCCcore', 'version': '14.3.0'}

github_account = name
source_urls = [GITHUB_SOURCE]
sources = ['v%(version)s.tar.gz']
patches = [
    '%(name)s-1.3.10_find-external-libs.patch',
    '%(name)s-1.3.10_fix-includes.patch',
    '%(name)s-1.3.10_install-libs-headers.patch',
]
checksums = [
    {'v1.3.10.tar.gz': '31900e4ad23f471310838f0ae6f6020b159bf5fa3d9826de285c4c91bfe0eeb2'},
    {'freebayes-1.3.10_find-external-libs.patch': '64027f589dc0344d4d009c0036dd1cfcb387b5bfdaabfa75a49046405aea18c5'},
    {'freebayes-1.3.10_fix-includes.patch': 'd72e594410590a968f8b8bd101483b142757a45ddabdf8406c5339e5b1a1cf1b'},
    {'freebayes-1.3.10_install-libs-headers.patch': '77566e9fc63bd22af97a033ab441e06bfb0f689e371c3f3ae02184d9498dab0c'},
]

# preconfigopts = 'EBVERSIONMESON=0.55.0 '

builddependencies = [
    ('CMake', '3.31.0'),
    ('Meson', '0.55.1'), #, versionsuffix),
    ('Ninja', '1.10.0'),
]

dependencies = [
    ('Python', '3.11'),
    ('SAMtools', '1.18'),
    ('intervaltree', '0.1'),
    ('libffi', '3.3'),
    ('SeqLib', '1.2.0'),
    ('vcflib', '1.0.9'),
    ('VCFtools', '0.1.16'),
]

configopts = "-Dprefer_system_deps=true --buildtype release"

postinstallcmds = [
    'echo %(builddir)s',
    'cp %(builddir)s/easybuild_obj/libfreebayes.{a,so} %(installdir)s/lib',
    'cp %(builddir)s/easybuild_obj/{freebayes,bamleftalign} %(installdir)s/bin',
    'chmod +x %(installdir)s/scripts/*.py',
]

sanity_check_paths = {
    'files': ['bin/%(name)s', 'bin/bamleftalign', 'scripts/%(name)s-parallel'],
    'dirs': ['bin', 'scripts'],
}
sanity_check_commands = ["%(name)s -h"]

modextrapaths = {'PATH': ['scripts']}

moduleclass = 'bio'

